---
// src/layouts/InsightsLayout.astro
// Layout for the /insights index and category pages — editorial magazine design
// matching the main christianfarioli.com look & feel:
//   1. Fixed nav (logo + main-site links + Insights active + Work Together CTA)
//   2. Insights hero (masthead: title + subtitle + live search)
//   3. Sticky category pill nav (links to category pages)
//   4. Featured article (2-col) — only when a featured/first article exists
//   5. Articles grid (3-col cards) — the rest
//   6. Future callout (light gradient panel)
//   7. Newsletter (dark)
//   8. Footer

import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS, INSIGHT_CATEGORIES, type InsightCategory } from '~/content.config';
import { publicOnly, sortByDateDesc, imageSrc, avatarSrc } from '~/lib/insights';
import { paths } from '~/lib/links';

interface Props {
  title: string;
  description?: string;
  /** Optional filter — show only this category. */
  category?: InsightCategory;
  /** Pre-rendered entries to render (passed from the page so we can use getStaticPaths). */
  entries: Awaited<ReturnType<typeof getCollection<'insights'>>>;
  /** Show only featured entries. */
  featuredOnly?: boolean;
}

const { title, description, category, entries: rawEntries, featuredOnly = false } = Astro.props;

// Apply workflow visibility: only public entries are listed
let entries = publicOnly(rawEntries);
if (category) entries = entries.filter((e) => e.data.category === category);
if (featuredOnly) entries = entries.filter((e) => e.data.featured);
entries = sortByDateDesc(entries);

// Pinned entries first, then by date desc
entries = [
  ...entries.filter((e) => e.data.pinned),
  ...entries.filter((e) => !e.data.pinned),
];

// Split: featured article (first one with featured: true), then the rest
const featured = entries.find((e) => e.data.featured) ?? entries[0];
const latest = entries.filter((e) => e.id !== featured?.id);

const categories = INSIGHT_CATEGORIES;
const currentPath = Astro.url.pathname;

// Main site lives at the domain root (one level up from /insights).
const main = paths.mainSite();
const heroSubtitle =
  description ??
  'Expert perspectives on AI strategy, human-centered leadership, and executive education.';

/** Initials for the author avatar fallback (e.g. "Christian Farioli" → "CF"). */
function initials(name: string): string {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((w) => w[0]?.toUpperCase() ?? '')
    .join('');
}

/** Human date label, e.g. "June 2026". */
function dateLabel(d?: Date): string | null {
  return d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) : null;
}
---
<BaseLayout title={title} description={heroSubtitle}>
  <!-- Navigation -->
  <nav class="nav" id="mainNav">
    <div class="nav-inner">
      <a href={main} class="nav-logo" aria-label="Prof. Christian Farioli — home">
        <img src="/imgs/logo-dark.png" alt="Prof. Christian Farioli" />
      </a>
      <div class="nav-links" id="navLinks">
        <a href={`${main}#positioning`} class="nav-link">About</a>
        <a href={`${main}#speaking`} class="nav-link">Speaking</a>
        <a href={paths.home()} class="nav-link active">Insights</a>
        <a href={`${main}#books`} class="nav-link">Books</a>
        <a href="/testimonials.html" class="nav-link">Testimonials</a>
        <a href="https://future.christianfarioli.com" target="_blank" rel="noopener" class="nav-link">Future</a>
        <a href={`${main}#contact`} class="nav-link">Contact</a>
        <a href={`${main}#cta`} class="nav-cta">Work Together</a>
      </div>
      <button class="nav-mobile-toggle" id="navToggle" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <main id="main">
    <!-- Hero masthead -->
    <section class="insights-hero">
      <div class="insights-hero-inner">
        <div class="insights-masthead">
          <div>
            <h1 class="insights-title">{category ? CATEGORY_LABELS[category] : 'Insights'}</h1>
            <p class="insights-subtitle">{heroSubtitle}</p>
          </div>
          <div class="search-container">
            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="M21 21l-4.35-4.35"></path>
            </svg>
            <label for="searchInput" class="sr-only">Search insights</label>
            <input type="text" class="search-input" placeholder="Search insights..." id="searchInput" autocomplete="off" />
          </div>
        </div>
      </div>
    </section>

    <!-- Category pills -->
    <nav class="category-nav" aria-label="Categories">
      <div class="category-inner">
        <div class="category-scroll">
          <a href={paths.home()} class:list={["category-btn", { active: currentPath === paths.home() }]}>All</a>
          {categories.map((c) => (
            <a
              href={paths.category(c)}
              class:list={["category-btn", { active: currentPath === paths.category(c) }]}
            >
              {CATEGORY_LABELS[c]}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Featured article -->
    {featured && (
      <section class="featured-section" id="featuredSection">
        <div class="featured-inner">
          <span class="section-label">Featured</span>
          <article class="featured-article">
            <a href={paths.insights(featured.id)} class="featured-image" aria-label={featured.data.title}>
              {featured.data.featuredImage && (
                <img src={imageSrc(featured.data.featuredImage)} alt={featured.data.featuredImageAlt} loading="lazy" />
              )}
              <span class="featured-badge">Must Read</span>
            </a>
            <div class="featured-content">
              <span class="featured-category">{CATEGORY_LABELS[featured.data.category]}</span>
              <h2 class="featured-title"><a href={paths.insights(featured.id)}>{featured.data.title}</a></h2>
              <p class="featured-excerpt">{featured.data.description}</p>
              <div class="featured-meta">
                {dateLabel(featured.data.publishedAt) && <span>{dateLabel(featured.data.publishedAt)}</span>}
                {featured.data.readingTime && (
                  <span>
                    <svg class="read-time-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <circle cx="12" cy="12" r="10"></circle><polyline points="12,6 12,12 16,14"></polyline>
                    </svg>
                    {featured.data.readingTime} min read
                  </span>
                )}
              </div>
            </div>
          </article>
        </div>
      </section>
    )}

    <!-- Articles grid -->
    <section class="articles-section">
      <div class="articles-inner">
        <div class="search-results-header" id="searchHeader" hidden>
          <p class="search-results-count" id="searchCount"></p>
        </div>
        {latest.length > 0 ? (
          <div class="articles-grid" id="articlesGrid">
            {latest.map((entry) => (
              <article
                class="article-card"
                data-search={`${entry.data.title} ${CATEGORY_LABELS[entry.data.category]} ${entry.data.description ?? ''}`}
              >
                <a href={paths.insights(entry.id)} class="article-card-image" aria-label={entry.data.title}>
                  {entry.data.featuredImage && (
                    <img src={imageSrc(entry.data.featuredImage)} alt={entry.data.featuredImageAlt} loading="lazy" />
                  )}
                  <span class="article-card-category">{CATEGORY_LABELS[entry.data.category]}</span>
                </a>
                <div class="article-card-content">
                  <h3 class="article-card-title"><a href={paths.insights(entry.id)}>{entry.data.title}</a></h3>
                  <p class="article-card-excerpt">{entry.data.description}</p>
                  <div class="article-card-footer">
                    <div class="article-card-author">
                      <span class="author-avatar-small">
                        {entry.data.author.avatar
                          ? <img src={avatarSrc(entry.data.author.avatar)} alt={entry.data.author.name} loading="lazy" />
                          : initials(entry.data.author.name)}
                      </span>
                      <span class="author-name">{entry.data.author.name}</span>
                    </div>
                    {entry.data.readingTime && (
                      <span class="read-time">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <circle cx="12" cy="12" r="10"></circle><polyline points="12,6 12,12 16,14"></polyline>
                        </svg>
                        {entry.data.readingTime} min
                      </span>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <p class="empty-state">No insights in this category yet — check back soon.</p>
        )}
        <div class="no-results" id="noResults" hidden>
          <h3>No matching insights</h3>
          <p>Try a different search term or browse by category above.</p>
        </div>
      </div>
    </section>

    <!-- Future callout -->
    <section class="future-callout">
      <div class="future-callout-wrap">
        <div class="future-callout-inner">
          <div class="future-callout-text">
            <span class="future-callout-eyebrow">Looking for practical AI resources?</span>
            <h2 class="future-callout-title">Explore <em>Future</em> for podcasts, frameworks, and weekly AI insights.</h2>
            <p class="future-callout-desc">Future is Prof. Christian Farioli's companion platform for leaders who want practical AI content between keynotes.</p>
            <ul class="future-callout-list">
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>Podcasts</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>Frameworks</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Community Resources</li>
              <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>Weekly AI Insights</li>
            </ul>
            <a href="https://future.christianfarioli.com" target="_blank" rel="noopener" class="btn-primary">
              Visit Future
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </div>
          <div class="future-callout-card">
            <div class="future-callout-card-tag">Future</div>
            <div class="future-callout-card-domain">future.christianfarioli.com</div>
            <p class="future-callout-card-tagline">Companion platform — practical AI, not keynote takeaways.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <section class="newsletter-section">
      <div class="newsletter-inner">
        <span class="newsletter-label">Newsletter</span>
        <h2 class="newsletter-title">Stay Ahead of the AI Curve</h2>
        <p class="newsletter-desc">Join executives and leaders receiving weekly insights on AI strategy, leadership, and the future of work.</p>
        <form class="newsletter-form" onsubmit="event.preventDefault(); this.querySelector('button').textContent='Subscribed ✓';">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input id="newsletter-email" type="email" class="newsletter-input" placeholder="Enter your email" required />
          <button type="submit" class="newsletter-btn">Subscribe</button>
        </form>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <h3>Prof. Christian Farioli</h3>
          <p>AI strategist, educator, speaker, author, and advisor helping leaders navigate artificial intelligence with clarity and strategic thinking.</p>
        </div>
        <div class="footer-links">
          <h4>Navigate</h4>
          <ul>
            <li><a href={`${main}#positioning`}>About</a></li>
            <li><a href={`${main}#speaking`}>Speaking</a></li>
            <li><a href={paths.home()}>Insights</a></li>
            <li><a href={`${main}#books`}>Books</a></li>
            <li><a href="/testimonials.html">Testimonials</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Resources</h4>
          <ul>
            <li><a href={paths.home()}>Insights</a></li>
            <li><a href="https://future.christianfarioli.com" target="_blank" rel="noopener">Future</a></li>
            <li><a href="https://future.christianfarioli.com/podcast" target="_blank" rel="noopener">Podcast</a></li>
            <li><a href="https://future.christianfarioli.com/newsletter" target="_blank" rel="noopener">Newsletter</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Categories</h4>
          <ul>
            {categories.slice(0, 4).map((c) => (
              <li><a href={paths.category(c)}>{CATEGORY_LABELS[c]}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-links">
          <h4>Connect</h4>
          <ul>
            <li><a href="https://linkedin.com/in/christianfarioli" target="_blank" rel="noopener">LinkedIn</a></li>
            <li><a href={`${main}#contact`}>Contact</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="footer-copyright">© {new Date().getFullYear()} Prof. Christian Farioli. All rights reserved.</span>
        <div class="footer-legal">
          <a href={`${main}#contact`}>Contact</a>
          <a href="https://future.christianfarioli.com" target="_blank" rel="noopener">Future</a>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>

<script is:inline>
  // Mobile nav toggle
  (function () {
    var t = document.getElementById('navToggle');
    var l = document.getElementById('navLinks');
    if (t && l) t.addEventListener('click', function () { t.classList.toggle('active'); l.classList.toggle('active'); });

    // Nav shadow on scroll
    var nav = document.getElementById('mainNav');
    function onScroll() { if (nav) nav.classList.toggle('scrolled', window.scrollY > 8); }
    window.addEventListener('scroll', onScroll, { passive: true }); onScroll();

    // Live client-side search over the cards on this page
    var input = document.getElementById('searchInput');
    var grid = document.getElementById('articlesGrid');
    var featuredSec = document.getElementById('featuredSection');
    var header = document.getElementById('searchHeader');
    var count = document.getElementById('searchCount');
    var noResults = document.getElementById('noResults');
    if (input && grid) {
      var cards = Array.prototype.slice.call(grid.querySelectorAll('.article-card'));
      input.addEventListener('input', function () {
        var q = input.value.trim().toLowerCase();
        if (!q) {
          cards.forEach(function (c) { c.style.display = ''; });
          if (featuredSec) featuredSec.style.display = '';
          if (header) header.hidden = true;
          if (noResults) noResults.hidden = true;
          return;
        }
        if (featuredSec) featuredSec.style.display = 'none';
        var n = 0;
        cards.forEach(function (c) {
          var hay = (c.getAttribute('data-search') || '').toLowerCase();
          var show = hay.indexOf(q) !== -1;
          c.style.display = show ? '' : 'none';
          if (show) n++;
        });
        if (header) { header.hidden = false; }
        if (count) { count.textContent = n + ' result' + (n === 1 ? '' : 's') + ' for "' + input.value + '"'; }
        if (noResults) noResults.hidden = n !== 0;
      });
    }
  })();
</script>

<style>
  :root {
    --color-bg-primary: #FAFAF8;
    --color-bg-secondary: #F5F4F0;
    --color-bg-dark: #1A1A1A;
    --color-text-primary: #0D0D0D;
    --color-text-secondary: #6B6B6B;
    --color-text-light: #F5F4F0;
    --color-accent: #CC0000;
    --color-accent-hover: #A30000;
    --color-border: #E8E7E3;
    --color-white: #FFFFFF;
    --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-accent: 'Playfair Display', Georgia, serif;
    --space-xs: 8px; --space-sm: 16px; --space-md: 24px; --space-lg: 32px;
    --space-xl: 48px; --space-2xl: 64px; --space-3xl: 96px; --space-4xl: 128px;
    --max-width: 1200px; --nav-height: 72px;
    --ease: cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(body) {
    font-family: var(--font-primary);
    background: var(--color-bg-primary);
    color: var(--color-text-primary);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    margin: 0;
  }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

  /* Navigation */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; height: var(--nav-height); z-index: 1000;
    background: rgba(250, 250, 248, 0.95); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--color-border); transition: box-shadow 0.4s var(--ease);
  }
  .nav.scrolled { box-shadow: 0 8px 30px rgba(0,0,0,0.06); }
  .nav-inner {
    max-width: var(--max-width); margin: 0 auto; padding: 0 var(--space-lg); height: 100%;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo { display: inline-flex; align-items: center; }
  .nav-logo img { height: 36px; width: auto; }
  .nav-links { display: flex; align-items: center; gap: var(--space-lg); }
  .nav-link {
    color: var(--color-text-primary); text-decoration: none; font-size: 14px; font-weight: 500;
    transition: color 0.3s ease; position: relative;
  }
  .nav-link::after {
    content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 1.5px;
    background: var(--color-accent); transition: width 0.4s var(--ease);
  }
  .nav-link:hover::after, .nav-link.active::after { width: 100%; }
  .nav-cta {
    background: var(--color-text-primary); color: var(--color-white) !important;
    padding: var(--space-xs) var(--space-md); border-radius: 6px; transition: background 0.3s var(--ease);
    font-size: 14px; font-weight: 500; text-decoration: none;
  }
  .nav-cta:hover { background: var(--color-accent); }
  .nav-mobile-toggle {
    display: none; flex-direction: column; justify-content: center; gap: 5px;
    width: 32px; height: 32px; cursor: pointer; background: none; border: none; padding: 0;
  }
  .nav-mobile-toggle span { display: block; width: 22px; height: 2px; background: var(--color-text-primary); transition: all 0.3s ease; margin: 0 auto; }
  .nav-mobile-toggle.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-mobile-toggle.active span:nth-child(2) { opacity: 0; }
  .nav-mobile-toggle.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Hero */
  .insights-hero {
    padding: calc(var(--nav-height) + var(--space-3xl)) 0 var(--space-2xl);
    background: linear-gradient(to bottom, var(--color-bg-secondary), var(--color-bg-primary));
  }
  .insights-hero-inner { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--space-lg); }
  .insights-masthead { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--space-xl); }
  .insights-title { font-family: var(--font-accent); font-size: clamp(36px, 5vw, 56px); font-weight: 500; letter-spacing: -0.02em; line-height: 1.1; margin: 0; }
  .insights-subtitle { font-size: 18px; color: var(--color-text-secondary); max-width: 600px; margin: var(--space-sm) 0 0; line-height: 1.7; }
  .search-container { position: relative; width: 100%; max-width: 360px; flex-shrink: 0; }
  .search-input {
    width: 100%; padding: var(--space-sm) var(--space-md) var(--space-sm) 48px;
    border: 1.5px solid var(--color-border); border-radius: 8px; font-size: 15px; font-family: var(--font-primary);
    background: var(--color-white); transition: all 0.3s var(--ease);
  }
  .search-input:focus { outline: none; border-color: var(--color-accent); box-shadow: 0 0 0 4px rgba(204,0,0,0.1); }
  .search-icon { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); width: 20px; height: 20px; color: var(--color-text-secondary); }

  /* Category pills */
  .category-nav {
    padding: var(--space-md) 0; border-bottom: 1px solid var(--color-border); position: sticky; top: var(--nav-height);
    background: rgba(250, 250, 248, 0.95); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); z-index: 100;
  }
  .category-inner { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--space-lg); }
  .category-scroll { display: flex; gap: var(--space-xs); overflow-x: auto; scrollbar-width: none; padding-bottom: var(--space-xs); }
  .category-scroll::-webkit-scrollbar { display: none; }
  .category-btn {
    padding: var(--space-xs) var(--space-md); border: 1.5px solid transparent; background: transparent;
    border-radius: 100px; font-size: 14px; font-weight: 500; color: var(--color-text-secondary);
    white-space: nowrap; text-decoration: none; transition: all 0.3s var(--ease);
  }
  .category-btn:hover { color: var(--color-text-primary); border-color: var(--color-border); }
  .category-btn.active { background: var(--color-text-primary); color: var(--color-white); border-color: var(--color-text-primary); }

  /* Section label */
  .section-label { display: inline-block; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-accent); margin-bottom: var(--space-md); }

  /* Featured */
  .featured-section { padding: var(--space-3xl) 0; }
  .featured-inner { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--space-lg); }
  .featured-article { display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--space-2xl); align-items: center; }
  .featured-image { position: relative; display: block; border-radius: 16px; overflow: hidden; aspect-ratio: 16/10; background: var(--color-bg-secondary); }
  .featured-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s var(--ease); }
  .featured-article:hover .featured-image img { transform: scale(1.03); }
