---
// src/layouts/InsightsLayout.astro
// Layout for the /insights index and category pages — site chrome + listing grid.
// Structure mirrors the original christianfarioli.com/insights.html:
//   1. Page header (eyebrow + h1 + lede)
//   2. Category strip
//   3. "Looking for practical AI resources?" → Future callout panel
//   4. Featured section (one large card with "Must Read" badge) — only when a featured article exists
//   5. Latest insights list (compact horizontal rows)
//   6. Newsletter call-to-action
//   7. Footer with author bio + nav columns

import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS, INSIGHT_CATEGORIES, type InsightCategory } from '~/content.config';
import { publicOnly, sortByDateDesc, imageSrc, avatarSrc } from '~/lib/insights';
import { paths } from '~/lib/links';

interface Props {
  title: string;
  description?: string;
  /** Optional filter — show only this category. */
  category?: InsightCategory;
  /** Pre-rendered entries to render (passed from the page so we can use getStaticPaths). */
  entries: Awaited<ReturnType<typeof getCollection<'insights'>>>;
  /** Show only featured entries. */
  featuredOnly?: boolean;
}

const { title, description, category, entries: rawEntries, featuredOnly = false } = Astro.props;

// Apply workflow visibility: only public entries are listed
let entries = publicOnly(rawEntries);
if (category) entries = entries.filter((e) => e.data.category === category);
if (featuredOnly) entries = entries.filter((e) => e.data.featured);
entries = sortByDateDesc(entries);

// Pinned entries first, then by date desc
entries = [
  ...entries.filter((e) => e.data.pinned),
  ...entries.filter((e) => !e.data.pinned),
];

// Split: featured article (first one with featured: true), then the rest
const featured = entries.find((e) => e.data.featured) ?? entries[0];
const latest = entries.filter((e) => e.id !== featured?.id);

const categories = INSIGHT_CATEGORIES;
const currentPath = Astro.url.pathname;
const articleCount = entries.length;
---
<BaseLayout title={title} description={description}>
  <main id="main">
    <!-- Header -->
    <section class="page-header">
      <div class="container">
        <span class="eyebrow">Insights</span>
        <h1>Insights</h1>
        {description && <p class="lede">{description}</p>}
      </div>
    </section>

    <!-- Category strip -->
    <nav class="category-strip" aria-label="Categories">
      <div class="container">
        <ul>
          <li><a href={paths.home()} class:list={[{ active: currentPath === paths.home() }]}>All Insights</a></li>
          {categories.map((c) => (
            <li>
              <a
                href={paths.category(c)}
                class:list={[{ active: currentPath === paths.category(c) }]}
              >
                {CATEGORY_LABELS[c]}
              </a>
            </li>
          ))}
          <li>
            <a href="https://christianfarioli.com#speaking" class="external-pill">Speaking &amp; Conferences</a>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Future callout -->
    <section class="future-callout">
      <div class="container callout-inner">
        <div class="callout-text">
          <h2>Looking for practical AI resources?</h2>
          <p>
            <strong>Explore <em>Future</em></strong> for podcasts, frameworks, and weekly AI insights.
          </p>
          <p class="muted">
            Future is Prof. Christian Farioli's companion platform for leaders who want practical AI content between keynotes.
          </p>
          <ul class="callout-list">
            <li>Podcasts</li>
            <li>Frameworks</li>
            <li>Community Resources</li>
            <li>Weekly AI Insights</li>
          </ul>
          <a href="https://future.christianfarioli.com" class="btn-primary">Visit Future →</a>
        </div>
        <aside class="callout-aside">
          <div class="callout-tag">Future</div>
          <div class="callout-domain">future.christianfarioli.com</div>
          <p class="callout-tagline">Companion platform — practical AI, not keynote takeaways.</p>
        </aside>
      </div>
    </section>

    <!-- Article count -->
    <section class="results-bar">
      <div class="container">
        <h2 class="results-heading">Search Results</h2>
        <p class="results-count">{articleCount} article{articleCount === 1 ? '' : 's'} found</p>
      </div>
    </section>

    <!-- Featured -->
    {featured && (
      <section class="featured-section">
        <div class="container">
          <h2 class="section-label">Featured</h2>
          <article class="featured-card">
            <a href={paths.insights(featured.id)} class="featured-card-link">
              <div class="featured-card-image">
                {featured.data.featuredImage && (
                  <img
                    src={imageSrc(featured.data.featuredImage)}
                    alt={featured.data.featuredImageAlt}
                    loading="lazy"
                  />
                )}
                <span class="must-read-badge">Must Read</span>
              </div>
              <div class="featured-card-body">
                <span class="card-eyebrow">{CATEGORY_LABELS[featured.data.category]}</span>
                <h3>{featured.data.title}</h3>
                <p>{featured.data.description}</p>
                <div class="card-meta">
                  {featured.data.publishedAt && (
                    <time datetime={featured.data.publishedAt.toISOString()}>
                      {featured.data.publishedAt.toLocaleDateString('en-US', {
                        year: 'numeric', month: 'long',
                      })}
                    </time>
                  )}
                  {featured.data.readingTime && (
                    <span class="meta-sep">·</span>
                  )}
                  {featured.data.readingTime && (
                    <span>{featured.data.readingTime} min read</span>
                  )}
                </div>
              </div>
            </a>
          </article>
        </div>
      </section>
    )}

    <!-- Latest insights list -->
    {latest.length > 0 && (
      <section class="latest-section">
        <div class="container">
          <h2 class="section-label">Latest Insights</h2>
          <ul class="latest-list">
            {latest.map((entry) => (
              <li class="latest-item">
                <a href={paths.insights(entry.id)} class="latest-link">
                  <div class="latest-thumb">
                    {entry.data.featuredImage && (
                      <img
                        src={imageSrc(entry.data.featuredImage)}
                        alt={entry.data.featuredImageAlt}
                        loading="lazy"
                      />
                    )}
                  </div>
                  <div class="latest-body">
                    <span class="card-eyebrow">{CATEGORY_LABELS[entry.data.category]}</span>
                    <h3>{entry.data.title}</h3>
                    <div class="card-meta card-meta-row">
                      {entry.data.author.avatar && (
                        <span class="meta-avatar">
                          <img
                            src={avatarSrc(entry.data.author.avatar)}
                            alt={entry.data.author.name}
                            loading="lazy"
                          />
                        </span>
                      )}
                      <span class="meta-author">{entry.data.author.name}</span>
                      {entry.data.readingTime && (
                        <>
                          <span class="meta-sep">·</span>
                          <span>{entry.data.readingTime} min</span>
                        </>
                      )}
                    </div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- Newsletter -->
    <section class="newsletter">
      <div class="container newsletter-inner">
        <div class="newsletter-text">
          <h2>Newsletter</h2>
          <p class="newsletter-headline">Stay Ahead of the AI Curve</p>
          <p class="newsletter-sub">
            Join executives and leaders receiving weekly insights on AI strategy, leadership, and the future of work.
          </p>
        </div>
        <form class="newsletter-form" onsubmit="event.preventDefault(); this.querySelector('button').textContent='Subscribed ✓';">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input id="newsletter-email" type="email" placeholder="you@company.com" required />
          <button type="submit" class="btn-primary">Subscribe</button>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ===========================================================
     Brand tokens (locally defined; match BaseLayout for site)
     =========================================================== */
  :root {
    --color-bg-primary: #fafaf8;
    --color-bg-secondary: #f0ede8;
    --color-text-primary: #1a1a1a;
    --color-text-secondary: #5a5a5a;
    --color-border: #e0ddd6;
    --color-white: #ffffff;
    --color-accent: #c8302f;
    --color-accent-hover: #a82524;
    --color-callout-bg: #0a3d4a;
    --color-callout-text: #ffffff;
    --font-body: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    --font-accent: 'Playfair Display', Georgia, serif;
    --radius-md: 8px;
    --radius-lg: 16px;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

  /* ===========================================================
     Page header
     =========================================================== */
  .page-header {
    padding: 80px 0 48px;
    text-align: center;
    background: var(--color-bg-primary);
  }
  .eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: 16px;
  }
  .page-header h1 {
    font-family: var(--font-accent);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 0 0 16px;
    color: var(--color-text-primary);
  }
  .lede {
    font-size: 18px;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 720px;
    margin: 0 auto;
  }

  /* ===========================================================
     Category strip
     =========================================================== */
  .category-strip {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 18px 0;
    background: var(--color-white);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .category-strip ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .category-strip a {
    display: inline-block;
    padding: 8px 16px;
    font-size: 14px;
    font-weight: 500;
    border-radius: 100px;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all 0.2s;
  }
  .category-strip a:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-secondary);
  }
  .category-strip a.active {
    color: var(--color-white);
    background: var(--color-text-primary);
  }
  .category-strip a.external-pill {
    border: 1px solid var(--color-border);
  }

  /* ===========================================================
     Future callout
     =========================================================== */
  .future-callout {
    padding: 64px 0;
    background: var(--color-bg-primary);
  }
  .callout-inner {
    background: var(--color-callout-bg);
    color: var(--color-callout-text);
    border-radius: var(--radius-lg);
    padding: 48px;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .callout-text h2 {
    font-family: var(--font-accent);
    font-size: 28px;
    font-weight: 500;
    margin: 0 0 16px;
    line-height: 1.25;
  }
  .callout-text p {
    margin: 0 0 12px;
    font-size: 16px;
    line-height: 1.6;
  }
  .callout-text .muted {
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 20px;
  }
  .callout-text em {
    font-family: var(--font-accent);
    font-style: italic;
    color: #b8e0c2;
  }
  .callout-list {
    list-style: none;
    margin: 0 0 24px;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 24px;
  }
  .callout-list li {
    position: relative;
    padding-left: 20px;
    font-size: 15px;
  }
  .callout-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #b8e0c2;
    font-weight: 700;
  }
  .callout-aside {
    border-left: 1px solid rgba(255, 255, 255, 0.2);
    padding-left: 32px;
  }
  .callout-tag {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #b8e0c2;
    margin-bottom: 8px;
  }
  .callout-domain {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .callout-tagline {
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
    margin: 0;
  }

  /* ===========================================================
     Buttons
     =========================================================== */
  .btn-primary {
    display: inline-block;
    background: var(--color-accent);
    color: var(--color-white);
    padding: 12px 24px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-primary:hover {
    background: var(--color-accent-hover);
  }
  .callout-text .btn-primary {
    background: #b8e0c2;
    color: #0a3d4a;
  }
  .callout-text .btn-primary:hover {
    background: #a5d4b0;
  }

  /* ===========================================================
     Results bar
     =========================================================== */
  .results-bar {
    padding: 32px 0 16px;
    background: var(--color-white);
  }
  .results-heading {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-secondary);
    margin: 0 0 4px;
  }
  .results-count {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ===========================================================
     Section labels (Featured, Latest Insights)
     =========================================================== */
  .section-label {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-secondary);
    margin: 0 0 24px;
  }

  /* ===========================================================
     Featured card (big horizontal)
     =========================================================== */
  .featured-section {
    padding: 32px 0 64px;
    background: var(--color-white);
  }
  .featured-card {
    background: var(--color-bg-primary);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .featured-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  }
  .featured-card-link {
    display: grid;
    grid-template-columns: 1fr 1fr;
    text-decoration: none;
    color: inherit;
  }
  .featured-card-image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-secondary);
  }
  .featured-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .must-read-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--color-accent);
    color: var(--color-white);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 12px;
    border-radius: 100px;
  }
  .featured-card-body {
    padding: 40px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .card-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 12px;
  }
  .featured-card-body h3 {
    font-family: var(--font-accent);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 16px;
    color: var(--color-text-primary);
  }
  .featured-card-body p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 0 0 20px;
  }
  .card-meta {
    display: flex;
    gap: 4px;
    align-items: center;
    font-size: 13px;
    color: var(--color-text-secondary);
  }
  .card-meta time, .card-meta span { display: inline-block; }
  .meta-sep { margin: 0 6px; }

  /* ===========================================================
     Latest list (compact horizontal rows)
     =========================================================== */
  .latest-section {
    padding: 32px 0 64px;
    background: var(--color-bg-primary);
  }
  .latest-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .latest-item {
    border-top: 1px solid var(--color-border);
  }
  .latest-item:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .latest-link {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 24px;
    padding: 24px 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }
  .latest-link:hover {
    background: rgba(200, 48, 47, 0.03);
  }
  .latest-link:hover h3 { color: var(--color-accent); }
  .latest-thumb {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
  }
  .latest-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .latest-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .latest-body h3 {
    font-family: var(--font-accent);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 12px;
    color: var(--color-text-primary);
    transition: color 0.2s;
  }
  .card-meta-row { margin-top: 4px; }
  .meta-avatar {
    display: inline-flex;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-bg-secondary);
    margin-right: 8px;
  }
  .meta-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .meta-author { font-weight: 500; color: var(--color-text-primary); }

  /* ===========================================================
     Newsletter
     =========================================================== */
  .newsletter {
    padding: 80px 0;
    background: var(--color-text-primary);
    color: var(--color-white);
  }
  .newsletter-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .newsletter-text h2 {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    margin: 0 0 16px;
  }
  .newsletter-headline {
    font-family: var(--font-accent);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 500;
    line-height: 1.15;
    margin: 0 0 12px;
  }
  .newsletter-sub {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }
  .newsletter-form {
    display: flex;
    gap: 8px;
  }
  .newsletter-form input {
    flex: 1;
    padding: 14px 20px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-white);
    border-radius: 100px;
    font-size: 15px;
    outline: none;
  }
  .newsletter-form input::placeholder { color: rgba(255, 255, 255, 0.5); }
  .newsletter-form input:focus {
    border-color: var(--color-accent);
    background: rgba(255, 255, 255, 0.08);
  }

  /* ===========================================================
     Responsive
     =========================================================== */
  @media (max-width: 900px) {
    .callout-inner { grid-template-columns: 1fr; padding: 32px; }
    .callout-aside { border-left: none; border-top: 1px solid rgba(255,255,255,0.2); padding-left: 0; padding-top: 24px; }
    .featured-card-link { grid-template-columns: 1fr; }
    .featured-card-image { aspect-ratio: 16/9; }
    .featured-card-body { padding: 32px 24px; }
    .latest-link { grid-template-columns: 120px 1fr; gap: 16px; }
    .newsletter-inner { grid-template-columns: 1fr; gap: 32px; }
  }
  @media (max-width: 600px) {
    .page-header { padding: 60px 0 32px; }
    .category-strip ul { gap: 4px; }
    .category-strip a { padding: 6px 12px; font-size: 13px; }
    .callout-list { grid-template-columns: 1fr; }
    .latest-link { grid-template-columns: 1fr; }
    .latest-thumb { aspect-ratio: 16/9; }
  }
</style>
