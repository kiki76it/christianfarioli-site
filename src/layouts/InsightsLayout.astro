---
// src/layouts/InsightsLayout.astro
// Layout for the /insights index and category pages — site chrome + listing grid.

import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS, INSIGHT_CATEGORIES, type InsightCategory } from '~/content.config';
import { publicOnly, sortByDateDesc, isCategory, imageSrc } from '~/lib/insights';
import { paths } from '~/lib/links';

interface Props {
  title: string;
  description?: string;
  /** Optional filter — show only this category. */
  category?: InsightCategory;
  /** Pre-rendered entries to render (passed from the page so we can use getStaticPaths). */
  entries: Awaited<ReturnType<typeof getCollection<'insights'>>>;
  /** Show only featured entries. */
  featuredOnly?: boolean;
}

const { title, description, category, entries: rawEntries, featuredOnly = false } = Astro.props;

// Apply workflow visibility: only public entries are listed
let entries = publicOnly(rawEntries);
if (category) entries = entries.filter((e) => e.data.category === category);
if (featuredOnly) entries = entries.filter((e) => e.data.featured);
entries = sortByDateDesc(entries);

// Pinned entries first, then by date desc
entries = [
  ...entries.filter((e) => e.data.pinned),
  ...entries.filter((e) => !e.data.pinned),
];

const categories = INSIGHT_CATEGORIES;
const currentPath = Astro.url.pathname;
---
<BaseLayout title={title} description={description}>
  <header class="insights-header">
    <div class="container">
      <span class="eyebrow">Insights</span>
      <h1>{title}</h1>
      {description && <p class="insights-lede">{description}</p>}
    </div>
  </header>

  <nav class="category-strip" aria-label="Categories">
    <div class="container">
      <ul>
        <li>
          <a href={paths.home()} class:list={[{ active: currentPath === paths.home() }]}>All</a>
        </li>
        {categories.map((c) => (
          <li>
            <a
              href={paths.category(c)}
              class:list={[{ active: currentPath === paths.category(c) }]}
            >
              {CATEGORY_LABELS[c]}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <main id="main" class="insights-main">
    <div class="container">
      {entries.length === 0 ? (
        <div class="empty-state">
          <p>No insights yet. <a href={paths.adminHome()}>Create the first one →</a></p>
        </div>
      ) : (
        <ul class="insights-grid">
          {entries.map((entry) => (
            <li class="insight-card">
              <a href={paths.insights(entry.id)}>
                {entry.data.featuredImage && (
                  <div class="insight-card-image">
                    <img
                      src={imageSrc(entry.data.featuredImage)}
                      alt={entry.data.featuredImageAlt}
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="insight-card-body">
                  <span class="insight-card-category">{CATEGORY_LABELS[entry.data.category]}</span>
                  <h3>{entry.data.title}</h3>
                  <p>{entry.data.description}</p>
                  <div class="insight-card-meta">
                    <span>{entry.data.author.name}</span>
                    {entry.data.publishedAt && (
                      <time datetime={entry.data.publishedAt.toISOString()}>
                        {entry.data.publishedAt.toLocaleDateString('en-US', {
                          year: 'numeric', month: 'short', day: 'numeric',
                        })}
                      </time>
                    )}
                    {entry.data.readingTime && (
                      <span>· {entry.data.readingTime} min read</span>
                    )}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .insights-header {
    padding: 80px 0 40px;
    text-align: center;
    background: var(--color-bg-primary);
  }
  .insights-header h1 {
    font-family: var(--font-accent);
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .insights-lede {
    font-size: 18px;
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  .category-strip {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 16px 0;
    background: var(--color-white);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .category-strip ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .category-strip a {
    display: inline-block;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 500;
    border-radius: 100px;
    color: var(--color-text-secondary);
    transition: all 0.2s;
  }
  .category-strip a:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-secondary);
  }
  .category-strip a.active {
    color: var(--color-white);
    background: var(--color-text-primary);
  }

  .insights-main {
    padding: 64px 0 96px;
  }

  .empty-state {
    text-align: center;
    padding: 80px 20px;
    color: var(--color-text-secondary);
  }
  .empty-state a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .insights-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
  }
  .insight-card a {
    display: block;
    color: inherit;
  }
  .insight-card a:hover h3 { color: var(--color-accent); }
  .insight-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    margin-bottom: 16px;
  }
  .insight-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .insight-card a:hover .insight-card-image img {
    transform: scale(1.03);
  }
  .insight-card-category {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 8px;
  }
  .insight-card h3 {
    font-family: var(--font-accent);
    font-size: 24px;
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 8px;
    transition: color 0.2s;
  }
  .insight-card p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0 0 12px;
  }
  .insight-card-meta {
    display: flex;
    gap: 8px;
    font-size: 12px;
    color: var(--color-text-secondary);
  }
  .insight-card-meta > *:not(:first-child)::before {
    content: '·';
    margin-right: 8px;
  }
</style>
