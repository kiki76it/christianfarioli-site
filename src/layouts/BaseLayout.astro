---
// src/layouts/BaseLayout.astro
// Root layout — page chrome, SEO, head tags. Every other layout extends this.

import '~/styles/global.css';
import { paths } from '~/lib/links';

interface Props {
  title: string;
  description?: string;
  /** OG image URL (absolute or root-relative). */
  ogImage?: string;
  /** Set to true to exclude from sitemap and search engines. */
  noindex?: boolean;
  /** Override the canonical URL. */
  canonical?: string;
  /** Page type for Open Graph. */
  ogType?: 'website' | 'article';
  /** Article published time (ISO 8601) — only for article pages. */
  publishedTime?: string;
  /** Article modified time (ISO 8601). */
  modifiedTime?: string;
}

const {
  title,
  description = 'Authority insights on AI strategy, leadership, and the future of work — by Prof. Christian Farioli.',
  ogImage,
  noindex = false,
  canonical,
  ogType = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || Astro.site?.toString() || 'https://christianfarioli.com/insights';
// Astro.url.pathname is the full path including BASE (e.g. "/insights/foo/").
// siteUrl is the full origin (e.g. "https://christianfarioli.com/insights").
// new URL(pathname, siteUrl) produces the correct absolute URL in both cases.
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const fullOgImage = ogImage
  ? ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).toString()
  : new URL(paths.favicon(), siteUrl).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={paths.favicon()} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:site_name" content="Christian Farioli — Authority Platform" />
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- JSON-LD: organization (every page) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Prof. Christian Farioli",
      "url": paths.mainSite(),
      "jobTitle": "AI Strategist, Educator, Speaker, Author & Advisor",
      "sameAs": [
        "https://www.linkedin.com/in/christianfarioli",
        "https://ae.linkedin.com/in/christianfarioli",
      ],
    })} />

    <!-- Preconnect to font CDN -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>
